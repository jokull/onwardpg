---
import PageLayout from 'blume/components/layout/PageLayout.astro';
import data from 'blume:data';
import heroImage from '../../../docs/assets/onwardpg.png';

const pageDescription = 'One evolving PostgreSQL migration for one compatibility-safe application deployment.';

const steps = [
  { number: '01', label: 'Expand', detail: 'Add the compatible surface while old code is still live.' },
  { number: '02', label: 'Deploy', detail: 'Ship one application version that understands both shapes.' },
  { number: '03', label: 'Drain', detail: 'Wait for old instances, workers, queues, and writes to finish.' },
  { number: '04', label: 'Contract', detail: 'Remove compatibility objects and converge on the desired schema.' },
];

const features = [
  { eyebrow: 'Compatibility-aware', title: 'Plan the shared schema', body: 'Generate expand and contract around the one application version that must understand both shapes.' },
  { eyebrow: 'Development-aware', title: 'Keep one plan alive', body: 'Capture intent, revise the same PlanID, and restack it as the feature and accepted base evolve.' },
  { eyebrow: 'Catalog-native', title: 'Know which diff this is', body: 'Keep replayed history, materialized working DDL, local development, production drift, and verification evidence distinct.' },
];
---

<PageLayout
  site={{ title: data.config.title, description: data.config.description }}
  logo={data.config.logo}
  favicon={data.config.favicon}
  appleIcon={data.config.appleIcon}
  banner={data.config.banner}
  analytics={data.config.analytics}
  navigation={data.navigation}
  themeMode={data.config.theme.mode}
  fontCssVars={data.fontCssVars}
  searchEnabled={data.config.search.enabled}
  siteUrl={data.config.site}
  ogEnabled={data.config.og.enabled}
  page={{
    title: 'onwardpg — one evolving migration',
    description: pageDescription,
    route: '/',
  }}
>
    <header class="nav shell">
      <a class="brand" href="/" aria-label="onwardpg home">
        <span class="trail" aria-hidden="true"></span>
        <span>onwardpg</span>
      </a>
      <nav aria-label="Main navigation">
        <a href="/start/introduction/">Docs</a>
        <a href="/guides/drizzle/">Frameworks</a>
        <a href="/delivery/github-actions/">CI</a>
        <a href="/agents/agent-assisted-planning/">Agents</a>
        <a class="github" href="https://github.com/jokull/onwardpg">GitHub <span>↗</span></a>
      </nav>
    </header>

    <div class="home-content">
      <section class="hero shell">
        <div class="hero-copy">
          <div class="kicker"><span></span> One evolving migration for one rolling deployment</div>
          <h1>One evolving migration.<br /><em>One safe deployment.</em></h1>
          <p class="lede">onwardpg plans the schema old and new code share, captures the decisions PostgreSQL cannot infer, and restacks the same migration as your feature and its base evolve.</p>
          <div class="actions">
            <a class="button primary" href="/concepts/plan-command/">Meet the plan command <span>→</span></a>
            <a class="button secondary" href="https://github.com/jokull/onwardpg">View on GitHub</a>
          </div>
          <div class="install" aria-label="Install command">
            <span class="prompt">$</span>
            <code>brew install jokull/tap/onwardpg</code>
            <button data-copy="brew install jokull/tap/onwardpg" aria-label="Copy install command">Copy</button>
          </div>
        </div>
        <figure class="hero-art">
          <img src={heroImage.src} width={heroImage.width} height={heroImage.height} alt="A traveler surveying a path through a distant PostgreSQL landscape" />
          <figcaption><span>01</span> Keep the feature, its history, and its route in view.</figcaption>
        </figure>
      </section>

      <section class="manifesto">
        <div class="shell manifesto-inner">
          <p class="section-label">Two capabilities. One workflow.</p>
          <h2>Plan compatibility.<br /><span>Capture intent as it evolves.</span></h2>
          <p>The SQL matters. So does remembering why it is correct when models change, another migration lands, or a branch-worn development database tells a different story.</p>
        </div>
      </section>

      <section class="plan-core shell" aria-labelledby="plan-title">
        <div class="plan-intro">
          <div>
            <p class="section-label">The core product</p>
            <h2 id="plan-title">One command holds the feature together.</h2>
          </div>
          <p><code>onwardpg plan</code> is not a stateless “here’s the diff, good luck.” The same command grows from a nullable column to an agent-authored type bridge beneath views and indexes, while onwardpg keeps dependency order, intent, and convergence proof intact.</p>
        </div>

        <div class="plan-grid">
          <div class="schema-states" aria-label="Schema states understood by onwardpg">
            <article><span>H</span><div><strong>Accepted history</strong><small>Replayed bundle chain</small></div><b>→ W</b></article>
            <article><span>W</span><div><strong>Working intent</strong><small>Exported DDL, ingested by PostgreSQL</small></div><b>durable</b></article>
            <article><span>D</span><div><strong>Development reality</strong><small>Read-only local catalog</small></div><b>→ W</b></article>
            <article><span>E</span><div><strong>Expand checkpoint</strong><small>Recorded by verification</small></div><b>P → E</b></article>
            <article><span>P</span><div><strong>Production reality</strong><small>Drift against H; readiness against E</small></div><b>read only</b></article>
            <article><span>V</span><div><strong>Verification</strong><small>Independent disposable replays</small></div><b>evidence</b></article>
          </div>

          <div class="plan-terminal" aria-label="Conceptual onwardpg plan report">
            <div class="terminal-bar"><span></span><span></span><span></span><small>checkout-preferences / active plan</small></div>
            <pre><code><span class="muted">$</span> onwardpg plan checkout-preferences

<span class="phase">DURABLE  H → W</span>
  accepted base    8 bundles replayed
  working schema   materialized from Drizzle
  plan_id          plan_a71…
  decision         rename carried forward

<span class="phase">DEVELOPMENT  D → W</span>
  preserved        table from another branch
  local question   rename draft-only column?

<span class="good">✓</span> base moved: same plan restacked
<span class="good">✓</span> 2 scoped decisions still valid</code></pre>
          </div>
        </div>

        <div class="plan-answers">
          <article><p>“My models changed again.”</p><strong>Revise the same PlanID.</strong><span>No stack of speculative fixup migrations.</span></article>
          <article><p>“Another migration landed.”</p><strong>Restack on replayed history.</strong><span>Carry valid decisions; invalidate changed meaning.</span></article>
          <article><p>“My dev DB is ahead.”</p><strong>Keep D → W separate.</strong><span>Preserve other-branch objects and local-only history.</span></article>
        </div>

        <a class="text-link" href="/concepts/plan-command/">Climb from easy to nightmare <span>→</span></a>
      </section>

      <section class="journey shell" aria-labelledby="journey-title">
        <div class="section-heading">
          <p class="section-label">The migration journey</p>
          <h2 id="journey-title">Your deployment sits in the middle—where it belongs.</h2>
        </div>
        <div class="route" aria-label="Expand, deploy, drain, contract">
          {steps.map((step, index) => (
            <article class:list={['route-step', { app: index === 1 }]}> 
              <span class="route-number">{step.number}</span>
              <div class="route-marker"><span></span></div>
              <h3>{step.label}</h3>
              <p>{step.detail}</p>
            </article>
          ))}
        </div>
        <a class="text-link" href="/concepts/expand-contract/">Understand the deployment contract <span>→</span></a>
      </section>

      <section class="proof">
        <div class="shell proof-grid">
          <div class="terminal" aria-label="Abridged projections of actual onwardpg plan output">
            <div class="terminal-bar"><span></span><span></span><span></span><small>add-booking-status / plan</small></div>
            <pre><code><span class="muted">$</span> onwardpg plan add-booking-status

<span class="warn">&#123;"status":"needs_action","durable":&#123;"status":"needs_input","generated_plan":&#123;"questions":[&#123;"choices":["assert_only","manual_sql","split_plan"]&#125;]&#125;&#125;&#125;</span>

<span class="muted">$</span> onwardpg plan add-booking-status \
  --hint '&#123;"kind":"reconcile","object":"column","name":["app","bookings","status"],"strategy":"manual_sql"&#125;' \
  --hint '&#123;"kind":"manual_sql","action":"reconcile_contract_sql","object":"column","name":["app","bookings","status"]&#125;'

<span class="warn">&#123;"status":"needs_action","durable":&#123;"status":"needs_sql_edits","edit_files":["phases/contract.sql"]&#125;&#125;</span>

<span class="phase">EXPAND</span>
  ALTER TABLE "app"."bookings" ADD COLUMN "status" text;

<span class="deploy">—— deploy application, then drain old traffic ——</span>

<span class="phase">CONTRACT</span>
  -- PRODUCT-SPECIFIC SQL: Provide reviewed reconcile_contract_sql SQL for app.bookings.status
  -- Verify: SELECT NOT EXISTS (SELECT 1 FROM "app"."bookings" WHERE "status" IS NULL);
  DO $onwardpg$ BEGIN IF NOT COALESCE((SELECT NOT EXISTS (SELECT 1 FROM "app"."bookings" WHERE "status" IS NULL)), false) THEN RAISE EXCEPTION 'onwardpg contract gate failed: data:1c16b884027de910'; END IF; END $onwardpg$;
  ALTER TABLE "app"."bookings" ALTER COLUMN "status" SET NOT NULL;

</code></pre>
          </div>
          <div class="proof-copy">
            <p class="section-label">Trust the evolving artifact</p>
            <h2>SQL you can inspect.<br />Intent that survives a rebase.</h2>
            <p>The bundle captures every consumed hint, edited pocket, hazard, assertion, and PostgreSQL major. Still-valid intent moves forward; stale answers fail.</p>
            <ul>
              <li><span>✓</span> Forward-only expand and contract SQL</li>
              <li><span>✓</span> Fingerprint-bound human decisions</li>
              <li><span>✓</span> Boolean data assertions</li>
              <li><span>✓</span> Empty residual diff required</li>
            </ul>
            <a class="button secondary dark" href="/concepts/verification/">See what verification proves</a>
          </div>
        </div>
      </section>

      <section class="features shell">
        <div class="section-heading compact">
          <p class="section-label">Why onwardpg</p>
          <h2>Built for the uncomfortable changes.</h2>
        </div>
        <div class="feature-grid">
          {features.map((feature, index) => (
            <article>
              <span class="feature-index">0{index + 1}</span>
              <p class="eyebrow">{feature.eyebrow}</p>
              <h3>{feature.title}</h3>
              <p>{feature.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="guides shell">
        <div class="section-heading compact">
          <p class="section-label">Bring your own schema source</p>
          <h2>Works after your framework, not instead of it.</h2>
          <p>Export complete PostgreSQL DDL from the tool you already use. onwardpg takes it from there.</p>
        </div>
        <div class="guide-links">
          <a href="/guides/drizzle/"><span class="guide-icon drizzle">D</span><span><strong>Drizzle</strong><small>drizzle-kit export</small></span><b>→</b></a>
          <a href="/guides/django/"><span class="guide-icon django">Dj</span><span><strong>Django</strong><small>migrate + pg_dump</small></span><b>→</b></a>
          <a href="/guides/prisma/"><span class="guide-icon prisma">P</span><span><strong>Prisma</strong><small>migrate diff</small></span><b>→</b></a>
          <a href="/guides/sqlalchemy/"><span class="guide-icon sqlalchemy">Sq</span><span><strong>SQLAlchemy</strong><small>Alembic + pg_dump</small></span><b>→</b></a>
        </div>
      </section>

      <section class="agents">
        <div class="shell agents-inner">
          <div class="agents-heading">
            <p class="section-label">Built for coding agents</p>
            <h2>Let the agent bring context.<br />Make the planner constrain it.</h2>
            <p>Agents can supply semantic decisions up front, compose product-aware backfills, and read structured plan output. onwardpg consumes only intent that matches a real decision and rejects stale or unused guesses.</p>
            <div class="agent-actions">
              <a class="button secondary dark" href="/agents/agent-assisted-planning/">Plan with an agent <span>→</span></a>
              <a class="agent-file" href="/skill.md">Point it at <code>/skill.md</code></a>
            </div>
          </div>
          <div class="agent-cards">
            <article><span>01</span><strong>Decide early</strong><p>Provide known rename, drop, rollout, or backfill intent on the first plan call.</p></article>
            <article><span>02</span><strong>Read production safely</strong><p>Use restricted read-only MCP queries for counts and value shapes—not copied rows or write authority.</p></article>
            <article><span>03</span><strong>Verify semantics</strong><p>Turn observed categories into synthetic <code>VALUES</code> assertions without retaining production data.</p></article>
          </div>
        </div>
      </section>

      <section class="cta">
        <div class="shell cta-inner">
          <div>
            <p class="section-label">Ready for the next change?</p>
            <h2>Start one plan.<br />Keep it alive.</h2>
          </div>
          <div class="cta-actions">
            <a class="button primary light" href="/start/installation/">Read the quickstart <span>→</span></a>
            <a href="/delivery/github-actions/">Wire it into CI</a>
          </div>
        </div>
      </section>
    </div>

    <footer class="shell" slot="footer">
      <a class="brand" href="/"><span class="trail" aria-hidden="true"></span><span>onwardpg</span></a>
      <p>Plan the compatibility window. PostgreSQL 15–18.</p>
      <div><a href="/reference/safety/">Safety</a><a href="https://github.com/jokull/onwardpg">GitHub</a></div>
    </footer>

    <script>
      document.querySelectorAll('[data-copy]').forEach((button) => {
        button.addEventListener('click', async () => {
          await navigator.clipboard.writeText(button.getAttribute('data-copy') || '');
          const previous = button.textContent;
          button.textContent = 'Copied';
          setTimeout(() => { button.textContent = previous; }, 1400);
        });
      });
    </script>
</PageLayout>

<style>
  :global(*) { box-sizing: border-box; }
  :global(html) { scroll-behavior: smooth; }
  :global(body) { margin: 0; overflow-x: clip; color: #26312c; background: #f8f3e7; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
  :global([data-blume-header]) { display: none; }
  :global(a) { color: inherit; }
  .shell { width: min(1180px, calc(100% - 48px)); margin-inline: auto; }
  .nav { height: 82px; display: flex; align-items: center; justify-content: space-between; }
  .brand { display: inline-flex; align-items: center; gap: 10px; font: 700 20px/1 ui-monospace, SFMono-Regular, Menlo, monospace; letter-spacing: -1px; text-decoration: none; }
  .trail { width: 27px; height: 24px; display: inline-block; border: solid #63705f; border-width: 0 0 3px 3px; border-radius: 0 0 0 16px; transform: skew(-24deg); position: relative; }
  .trail::after { content: ''; position: absolute; width: 17px; height: 13px; border: solid #63705f; border-width: 0 0 2px 2px; border-radius: 0 0 0 12px; left: 6px; top: 4px; }
  .nav nav { display: flex; align-items: center; gap: 28px; font-size: 14px; }
  .nav nav a { text-decoration: none; color: #4f5852; }
  .nav nav a:hover { color: #17201b; }
  .nav nav .github { padding-left: 27px; border-left: 1px solid #d6cdb9; color: #26312c; font-weight: 650; }
  .hero { min-height: 690px; display: grid; grid-template-columns: .92fr 1.08fr; gap: 58px; align-items: center; padding-block: 52px 80px; }
  .hero-copy { min-width: 0; padding-top: 8px; position: relative; z-index: 1; }
  .kicker, .section-label, .eyebrow { color: #66705f; font: 700 11px/1.3 ui-monospace, SFMono-Regular, Menlo, monospace; letter-spacing: .13em; text-transform: uppercase; }
  .kicker { display: flex; align-items: center; gap: 10px; }
  .kicker span { width: 32px; height: 1px; background: #8c967e; }
  h1 { margin: 25px 0 22px; color: #222b26; font: 500 clamp(54px, 6.1vw, 84px)/.93 Georgia, "Times New Roman", serif; letter-spacing: -.055em; }
  h1 em { color: #65705e; font-weight: 400; }
  .lede { max-width: 590px; margin: 0; color: #59615b; font-size: 18px; line-height: 1.65; }
  .actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 34px; }
  .button { min-height: 48px; display: inline-flex; justify-content: center; align-items: center; gap: 18px; padding: 0 20px; border: 1px solid #cfc5b0; border-radius: 3px; text-decoration: none; font-weight: 700; font-size: 13px; }
  .button.primary { color: #fbf6e9; background: #344139; border-color: #344139; }
  .button.primary:hover { background: #202b25; }
  .button.secondary { background: rgba(255,255,255,.28); }
  .button.secondary:hover { border-color: #808a79; }
  .button span { font-size: 18px; }
  .install { height: 47px; margin-top: 24px; display: flex; align-items: center; max-width: 430px; border: 1px solid #d9d0bd; border-radius: 3px; background: rgba(255,255,255,.32); font-size: 12px; }
  .install .prompt { padding-left: 15px; color: #83907a; }
  .install code { min-width: 0; padding: 0 9px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .install button { margin-left: auto; height: 100%; padding: 0 13px; border: 0; border-left: 1px solid #d9d0bd; background: transparent; color: #66705f; cursor: pointer; font: inherit; }
  .hero-art { margin: 0; align-self: stretch; min-height: 560px; position: relative; overflow: hidden; border-radius: 3px; box-shadow: 0 30px 80px rgba(48,55,47,.13); background: #e9dfc9; }
  .hero-art::after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, rgba(248,243,231,.4), transparent 28%), linear-gradient(0deg, rgba(24,31,27,.18), transparent 34%); pointer-events: none; }
  .hero-art img { width: 100%; height: 100%; min-height: 560px; object-fit: cover; object-position: 55% center; filter: saturate(.78) contrast(.96); }
  .hero-art figcaption { position: absolute; z-index: 1; left: 24px; right: 24px; bottom: 20px; display: flex; align-items: center; gap: 12px; color: #f8f3e7; font-size: 12px; text-shadow: 0 1px 8px rgba(0,0,0,.5); }
  .hero-art figcaption span { padding-right: 12px; border-right: 1px solid rgba(255,255,255,.5); font-family: ui-monospace, monospace; }
  .manifesto { background: #29342e; color: #f2ead8; }
  .manifesto-inner { padding-block: 92px 100px; display: grid; grid-template-columns: .7fr 2fr 1fr; gap: 48px; align-items: start; }
  .manifesto .section-label { color: #b8bdab; margin-top: 13px; }
  .manifesto h2, .plan-core h2, .journey h2, .proof h2, .features h2, .guides h2, .agents h2, .cta h2 { margin: 0; font: 500 clamp(36px, 4.3vw, 58px)/1.05 Georgia, "Times New Roman", serif; letter-spacing: -.035em; }
  .manifesto h2 span { color: #c8b979; }
  .manifesto-inner > p:last-child { color: #bfc5ba; line-height: 1.7; margin: 8px 0 0; }
  .plan-core { padding-block: 115px 125px; }
  .plan-intro { display: grid; grid-template-columns: 1.15fr .85fr; gap: 80px; align-items: end; }
  .plan-intro h2 { max-width: 660px; margin-top: 17px; }
  .plan-intro > p { margin: 0 0 4px; color: #626b63; line-height: 1.75; }
  .plan-intro code { padding: 2px 5px; border: 1px solid #d5ccba; border-radius: 3px; font-size: .88em; }
  .plan-grid { margin-top: 65px; display: grid; grid-template-columns: .82fr 1.18fr; border: 1px solid #bcb7aa; background: rgba(255,255,255,.18); }
  .schema-states { padding: 19px 27px; display: grid; align-content: center; }
  .schema-states article { min-height: 76px; display: grid; grid-template-columns: 38px 1fr auto; gap: 15px; align-items: center; border-bottom: 1px solid #d8d0bf; }
  .schema-states article:last-child { border-bottom: 0; }
  .schema-states article > span { width: 34px; height: 34px; display: grid; place-items: center; border-radius: 50%; color: #f8f3e7; background: #536253; font: 800 12px ui-monospace, monospace; }
  .schema-states article:nth-child(2) > span { color: #273129; background: #cbb873; }
  .schema-states article div { min-width: 0; display: grid; gap: 5px; }
  .schema-states strong { font-size: 13px; }
  .schema-states small { overflow: hidden; color: #747b74; font-size: 11px; text-overflow: ellipsis; white-space: nowrap; }
  .schema-states b { color: #778176; font: 700 10px ui-monospace, monospace; text-transform: uppercase; }
  .plan-terminal { min-width: 0; color: #eae9df; background: #202923; }
  .plan-terminal pre { margin: 0; padding: 31px; overflow-x: auto; font: 12px/1.78 ui-monospace, SFMono-Regular, Menlo, monospace; }
  .plan-terminal .muted { color: #7d8a81; }.plan-terminal .good { color: #a8c493; }.plan-terminal .phase { color: #e6cc7e; font-weight: 800; }
  .plan-answers { display: grid; grid-template-columns: repeat(3, 1fr); border: solid #bcb7aa; border-width: 0 1px 1px; }
  .plan-answers article { min-height: 160px; padding: 26px; display: grid; align-content: start; gap: 8px; }
  .plan-answers article + article { border-left: 1px solid #d1c9b8; }
  .plan-answers p { margin: 0; color: #7a8079; font: 11px ui-monospace, monospace; }
  .plan-answers strong { font: 500 21px/1.15 Georgia, serif; }
  .plan-answers span { color: #69716b; font-size: 13px; line-height: 1.55; }
  .plan-core > .text-link { margin-top: 35px; }
  .journey { padding-block: 110px 120px; }
  .section-heading { max-width: 800px; }
  .section-heading h2 { margin-top: 17px; }
  .route { margin-top: 70px; display: grid; grid-template-columns: repeat(4, 1fr); }
  .route-step { min-height: 230px; position: relative; padding-right: 34px; }
  .route-number { color: #90988c; font: 12px ui-monospace, monospace; }
  .route-marker { height: 48px; margin-top: 15px; position: relative; display: flex; align-items: center; }
  .route-marker::after { content: ''; position: absolute; left: 0; right: 0; height: 1px; background: #c9c4b6; }
  .route-marker span { position: relative; z-index: 1; width: 13px; height: 13px; border: 2px solid #59685a; border-radius: 50%; background: #f8f3e7; }
  .route-step.app .route-marker span { width: 19px; height: 19px; border: 5px solid #d3b767; box-shadow: 0 0 0 5px #344139; background: #344139; }
  .route-step h3 { margin: 15px 0 10px; font-size: 18px; }
  .route-step p { max-width: 220px; margin: 0; color: #69716b; font-size: 14px; line-height: 1.65; }
  .text-link { display: inline-flex; gap: 12px; color: #455344; font-weight: 700; font-size: 13px; text-underline-offset: 5px; }
  .proof { background: #e8dfcb; padding-block: 110px; }
  .proof-grid { display: grid; grid-template-columns: 1.2fr .8fr; gap: 90px; align-items: center; }
  .terminal { overflow: hidden; border: 1px solid #4b554d; border-radius: 6px; color: #eae9df; background: #202923; box-shadow: 0 28px 60px rgba(36,42,37,.2); }
  .terminal-bar { height: 42px; display: flex; align-items: center; gap: 7px; padding: 0 14px; border-bottom: 1px solid #39443d; }
  .terminal-bar span { width: 8px; height: 8px; border-radius: 50%; background: #667268; }
  .terminal-bar span:first-child { background: #c67967; }
  .terminal-bar span:nth-child(2) { background: #d5b96e; }
  .terminal-bar small { margin-left: 8px; color: #8f9990; font: 10px ui-monospace, monospace; }
  .terminal pre { margin: 0; padding: 29px; overflow-x: auto; font: 12px/1.75 ui-monospace, SFMono-Regular, Menlo, monospace; }
